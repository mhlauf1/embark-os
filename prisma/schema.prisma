generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Location {
  id           String    @id @default(cuid())
  slug         String    @unique
  name         String
  address      String?
  city         String
  state        String
  phone        String?
  acquiredAt   DateTime?
  facilityType String

  // Services offered
  serviceBoarding    Boolean @default(false)
  serviceDaycare     Boolean @default(false)
  serviceGrooming    Boolean @default(false)
  serviceTraining    Boolean @default(false)
  serviceVetCare     Boolean @default(false)
  serviceGroomingEd  Boolean @default(false)
  serviceWebcams     Boolean @default(false)
  serviceMobileGroom Boolean @default(false)
  serviceRetail      Boolean @default(false)

  // Website - current state
  currentUrl        String?
  currentPlatform   String?
  currentTechStack  String?
  lighthousePerf    Int?
  lighthouseA11y    Int?
  lighthouseSEO     Int?
  lighthouseBP      Int?
  lighthouseMobilePerf  Int?
  lighthouseMobileA11y  Int?
  lighthouseMobileSEO   Int?
  lighthouseMobileBP    Int?
  lighthouseAudited DateTime?
  googleRating      Float?
  googleReviewCount Int?

  // Website - rebuild state
  rebuildStatus    String  @default("not-scoped")
  rebuildTemplate  String?
  previewUrl       String?
  targetLaunchDate DateTime?
  liveUrl          String?

  // Website functional requirements
  needsOnlineBooking     Boolean @default(false)
  needsWebcamFeed        Boolean @default(false)
  needsPricingCalculator Boolean @default(false)
  needsStaffPage         Boolean @default(false)
  needsServicePages      Boolean @default(false)
  needsPhotoGallery      Boolean @default(false)
  needsContactForm       Boolean @default(false)
  needsMapsEmbed         Boolean @default(false)
  needsReviewsWidget     Boolean @default(false)

  // Infrastructure
  domainRegistrar      String?
  dnsProvider          String?
  nameservers          String?
  hostingProvider      String?
  emailPlatform        String?
  mxStatus             String?
  spfStatus            String?
  dkimStatus           String?
  infraNotes           String?
  secondaryDomain      String?
  secondaryDomainNotes String?

  // Migration status
  migrationStatus    String @default("not-started")
  migrationBlockedBy String?
  migrationNotes     String?

  // Assets
  hasLogoVector  Boolean @default(false)
  hasLogoRaster  Boolean @default(false)
  hasBrandColors Boolean @default(false)
  hasPhotography String  @default("none")
  assetNotes     String?

  // Relations
  contacts           Contact[]
  notes              Note[]
  competitors        Competitor[]
  ratingSnapshots    RatingSnapshot[]
  auditSnapshots     AuditSnapshot[]
  seoSnapshots       SeoSnapshot[]
  aiVisibilityChecks AIVisibilityCheck[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SeoSnapshot {
  id             String   @id @default(cuid())
  locationId     String
  location       Location @relation(fields: [locationId], references: [id], onDelete: Cascade)
  url            String
  overallScore   Int      // 0-100
  letterGrade    String   // "A+" through "F"
  responseTimeMs Int
  checkResults   String   // JSON string of SeoCheckResult[]
  createdAt      DateTime @default(now())

  @@index([locationId, createdAt])
}

model AuditSnapshot {
  id           String   @id @default(cuid())
  locationId   String
  location     Location @relation(fields: [locationId], references: [id], onDelete: Cascade)
  strategy     String   // "desktop" | "mobile"
  url          String
  scorePerf    Int
  scoreA11y    Int
  scoreSEO     Int
  scoreBP      Int
  overallScore Float
  letterGrade  String   // "A+" through "F"
  auditDetails String   // Full PSI response as JSON string
  createdAt    DateTime @default(now())

  @@index([locationId, strategy, createdAt])
}

model RatingSnapshot {
  id                String   @id @default(cuid())
  locationId        String
  location          Location @relation(fields: [locationId], references: [id], onDelete: Cascade)
  googleRating      Float
  googleReviewCount Int
  recordedAt        DateTime @default(now())

  @@index([locationId, recordedAt])
}

model Competitor {
  id                String   @id @default(cuid())
  locationId        String
  location          Location @relation(fields: [locationId], references: [id], onDelete: Cascade)
  name              String
  url               String?
  googleRating      Float?
  googleReviewCount Int?
  notes             String?
  placeId           String?
  seoScore          Int?
  seoGrade          String?

  // Services (mirror Location)
  serviceBoarding    Boolean @default(false)
  serviceDaycare     Boolean @default(false)
  serviceGrooming    Boolean @default(false)
  serviceTraining    Boolean @default(false)
  serviceVetCare     Boolean @default(false)
  serviceGroomingEd  Boolean @default(false)
  serviceWebcams     Boolean @default(false)
  serviceMobileGroom Boolean @default(false)
  serviceRetail      Boolean @default(false)

  // Lighthouse scores
  lighthousePerf       Int?
  lighthouseA11y       Int?
  lighthouseSEO        Int?
  lighthouseBP         Int?
  lighthouseMobilePerf Int?
  lighthouseMobileA11y Int?
  lighthouseMobileSEO  Int?
  lighthouseMobileBP   Int?
  lighthouseAudited    DateTime?

  // Relations
  snapshots       CompetitorSnapshot[]
  ratingSnapshots CompetitorRatingSnapshot[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CompetitorSnapshot {
  id             String     @id @default(cuid())
  competitorId   String
  competitor     Competitor @relation(fields: [competitorId], references: [id], onDelete: Cascade)
  strategy       String     // "desktop" | "mobile"
  url            String
  scorePerf      Int
  scoreA11y      Int
  scoreSEO       Int
  scoreBP        Int
  overallScore   Float
  letterGrade    String
  auditDetails   String     // JSON blob
  seoScore       Int?
  seoGrade       String?
  seoChecks      String?    // JSON: SeoCheckResult[]
  responseTimeMs Int?
  createdAt      DateTime   @default(now())

  @@index([competitorId, strategy, createdAt])
}

model CompetitorRatingSnapshot {
  id                String     @id @default(cuid())
  competitorId      String
  competitor        Competitor @relation(fields: [competitorId], references: [id], onDelete: Cascade)
  googleRating      Float
  googleReviewCount Int
  recordedAt        DateTime   @default(now())

  @@index([competitorId, recordedAt])
}

model AIVisibilityCheck {
  id                   String   @id @default(cuid())
  locationId           String
  location             Location @relation(fields: [locationId], references: [id], onDelete: Cascade)
  prompt               String
  promptSlug           String
  model                String
  response             String
  mentionsEmbark       Boolean  @default(false)
  embarkPosition       Int?
  mentionedNames       String   // JSON: string[]
  competitorsMentioned String   // JSON: { name, position }[]
  createdAt            DateTime @default(now())

  @@index([locationId, promptSlug, createdAt])
}

model Contact {
  id         String   @id @default(cuid())
  locationId String
  location   Location @relation(fields: [locationId], references: [id], onDelete: Cascade)

  name      String
  email     String?
  phone     String?
  role      String
  company   String?
  notes     String?
  isPrimary Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Note {
  id         String   @id @default(cuid())
  locationId String
  location   Location @relation(fields: [locationId], references: [id], onDelete: Cascade)

  body       String
  author     String  @default("Mike")
  isBlocker  Boolean @default(false)
  isResolved Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
